import re
import traceback
import uuid
from typing import Dict, Optional, Callable

import groq
from e2b_code_interpreter import Sandbox
from github import Github, InputGitTreeElement
from sqlalchemy.orm import Session

from config import Config
from database import Project, ProjectOutput
from models import ProjectStatus, StepName, Language, DeployTarget, PipelineEvent


class BossAgentPipeline:
    """Synchronous 9-step pipeline: Init -> Plan -> Code -> Test -> Refactor -> Docs -> Deploy -> Complete."""

    def __init__(
        self,
        project_id: uuid.UUID,
        project_name: str,
        description: str,
        db: Session,
        publish_event: Optional[Callable] = None,
    ):
        self.project_id = project_id
        self.project_name = project_name
        self.description = description
        self.db = db
        self.publish_event = publish_event or self._default_publish
        self.groq_client = groq.Groq(api_key=Config.GROQ_API_KEY)
        self.github_client = Github(Config.GITHUB_ACCESS_TOKEN) if Config.GITHUB_ACCESS_TOKEN else None
        self.sandbox = None
        print(f"[Init] Pipeline created for {self.project_name}")

    def _default_publish(self, event: PipelineEvent):
        print(f"[{event.step.value}] [{event.event_type}] {event.message}")

    def _emit(self, step: StepName, msg: str, event_type: str = "log"):
        self.publish_event(PipelineEvent(step=step, message=msg, event_type=event_type))

    # ---------------- DB Helpers ----------------

    def _update_status(self, status: ProjectStatus, repo_url: Optional[str] = None):
        project = self.db.query(Project).filter(Project.project_id == self.project_id).first()
        if project:
            project.status = status.value
            if repo_url:
                project.repo_url = repo_url
            self.db.commit()

    def _record(self, step: StepName, content: str):
        output = ProjectOutput(
            project_id=self.project_id,
            step_name=step.value,
            output_content=content,
        )
        self.db.add(output)
        self.db.commit()

    # ---------------- LLM ----------------

    def _llm(self, system: str, user: str) -> str:
        response = self.groq_client.chat.completions.create(
            messages=[
                {"role": "system", "content": system},
                {"role": "user", "content": user},
            ],
            model=Config.GROQ_MODEL_NAME,
            temperature=0.7,
            max_tokens=4096,
        )
        return response.choices[0].message.content

    # ---------------- Sandbox ----------------

    def _init_sandbox(self):
        if not self.sandbox:
            self.sandbox = Sandbox(api_key=Config.E2B_API_KEY)
            self._emit(StepName.INIT, "E2B sandbox ready")

    def _sandbox_exec(self, cmd: str) -> str:
        self._init_sandbox()
        proc = self.sandbox.process.start(cmd)
        proc.wait()
        if proc.exit_code != 0:
            raise RuntimeError(f"Sandbox command failed: {proc.stderr}")
        return proc.stdout

    def _sandbox_write(self, path: str, content: str):
        self._init_sandbox()
        self.sandbox.filesystem.write(path, content)

    def _sandbox_read(self, path: str) -> str:
        self._init_sandbox()
        return self.sandbox.filesystem.read(path)

    def _cleanup_sandbox(self):
        if self.sandbox:
            try:
                self.sandbox.close()
            except Exception:
                pass
            self.sandbox = None

    # ---------------- GitHub ----------------

    def _create_github_repo(self, repo_name: str) -> str:
        if not self.github_client:
            raise RuntimeError("GitHub token not configured")
        user = self.github_client.get_user()
        repo = user.create_repo(repo_name, description=self.description, private=False, auto_init=True)
        return repo.html_url

    def _push_files_to_github(self, repo_url: str, files: Dict[str, str]):
        if not self.github_client:
            raise RuntimeError("GitHub token not configured")
        repo_path = repo_url.split("github.com/")[1]
        repo = self.github_client.get_repo(repo_path)
        ref = repo.get_git_ref("heads/main")
        base_tree = repo.get_git_tree(ref.object.sha)
        elements = [InputGitTreeElement(path, "100644", "blob", content) for path, content in files.items()]
        tree = repo.create_git_tree(elements, base_tree)
        parent = repo.get_git_commit(ref.object.sha)
        commit = repo.create_git_commit(f"Boss Agent: Initial project generation for {self.project_name}", tree, [parent])
        ref.edit(commit.sha)

    # ---------------- Pipeline Steps ----------------

    def _step_plan(self) -> str:
        self._emit(StepName.PLANNING, "Generating project plan...", "status")
        plan = self._llm(
            "You are an expert software architect. Create a detailed project plan including: goals, key features, tech stack, file structure, architecture, and dev steps. Output in markdown.",
            f"Project: {self.project_name}\nDescription: {self.description}",
        )
        self._record(StepName.PLANNING, plan)
        self._emit(StepName.PLANNING, "Project plan complete", "result")
        return plan

    def _step_code(self, plan: str, target_lang: Optional[Language] = None) -> str:
        self._emit(StepName.CODING, "Generating code...", "status")
        lang = target_lang.value if target_lang else "Python"
        code = self._llm(
            f"""You are an expert {lang} developer. Generate ALL project files.
For each file use this format:
```{lang.lower()}:filename.ext
<content>
```
Output COMPLETE functional code. No placeholders.""",
            f"Project: {self.project_name}\nPlan:\n{plan}",
        )
        self._record(StepName.CODING, code)
        self._emit(StepName.CODING, "Code generation complete", "result")
        return code

    def _step_extract(self, code_output: str) -> Dict[str, str]:
        """Parse markdown code blocks with filenames like ```python:main.py"""
        pattern = re.compile(r"```(?:\w+):(?:\s.*?)?([^\n]+)\n(.*?)```", re.DOTALL)
        files: Dict[str, str] = {}
        for match in pattern.finditer(code_output):
            fname = match.group(1).strip()
            content = match.group(2).strip()
            files[fname] = content
        if not files:
            # Fallback: treat entire output as main.py
            files["main.py"] = code_output
        self._emit(StepName.CODING, f"Extracted {len(files)} files: {list(files.keys())}", "result")
        return files

    def _step_test(self, files: Dict[str, str], target_lang: Optional[Language] = None) -> str:
        self._emit(StepName.TESTING, "Testing code in sandbox...", "status")
        self._init_sandbox()

        # Write all files
        for fname, content in files.items():
            self._sandbox_write(fname, content)

        # Install deps if requirements.txt exists
        if "requirements.txt" in files:
            try:
                self._sandbox_exec("pip install -r requirements.txt")
            except RuntimeError as e:
                self._emit(StepName.TESTING, f"Dep install warning: {e}", "error")

        # Determine main file
        main_file = None
        for candidate in ["main.py", "app.py", "index.js", "main.go"]:
            if candidate in files:
                main_file = candidate
                break
        if not main_file:
            for f in files:
                if f.endswith((".py", ".js", ".go")):
                    main_file = f
                    break

        if not main_file:
            return "No executable file found - skipping test"

        cmd = "python" if main_file.endswith(".py") else "node" if main_file.endswith(".js") else "go run"
        result = self._sandbox_exec(f"{cmd} {main_file}")
        self._record(StepName.TESTING, f"Test passed:\n{result}")
        self._emit(StepName.TESTING, "Tests passed", "result")
        return result

    def _step_refactor(self, code_output: str, plan: str) -> str:
        self._emit(StepName.REFACTORING, "Reviewing & refactoring code...", "status")
        reviewed = self._llm(
            """You are an expert code reviewer. Review the code for bugs, security issues, and best practices.
Output the IMPROVED code using the same ```lang:filename format.
Fix all issues in-place.""",
            f"Plan:\n{plan}\n\nCode:\n{code_output}",
        )
        self._record(StepName.REFACTORING, reviewed)
        self._emit(StepName.REFACTORING, "Code review & refactoring complete", "result")
        return reviewed

    def _step_docs(self, plan: str, code: str) -> str:
        self._emit(StepName.DOCUMENTATION, "Generating documentation...", "status")
        readme = self._llm(
            """Generate a comprehensive README.md including: title, description, setup, usage, API reference if applicable, and tech stack.
Output ONLY markdown content.""",
            f"Project: {self.project_name}\nPlan:\n{plan}\n\nCode:\n{code}",
        )
        self._record(StepName.DOCUMENTATION, readme)
        self._emit(StepName.DOCUMENTATION, "Documentation complete", "result")
        return readme

    def _step_deploy(self, files: Dict[str, str], readme: str, repo_url: Optional[str] = None) -> str:
        self._emit(StepName.DEPLOYMENT, "Deploying to GitHub...", "status")
        if not repo_url:
            repo_name = self.project_name.lower().replace(" ", "-") + f"-ai"
            repo_url = self._create_github_repo(repo_name)

        # Add README
        files["README.md"] = readme

        self._push_files_to_github(repo_url, files)
        self._update_status(ProjectStatus.RUNNING, repo_url=repo_url)
        self._record(StepName.DEPLOYMENT, f"Deployed to: {repo_url}")
        self._emit(StepName.DEPLOYMENT, f"Deployed to {repo_url}", "result")
        return repo_url

    # ---------------- Main Runner ----------------

    def run_pipeline(
        self,
        initial_prompt: Optional[str] = None,
        project_type: Optional[str] = None,
        target_language: Optional[Language] = None,
        deploy_target: Optional[DeployTarget] = None,
    ):
        self._emit(StepName.INIT, "Pipeline started", "status")
        self._update_status(ProjectStatus.RUNNING)

        try:
            # 1. Plan
            plan = self._step_plan()

            # 2. Code
            code_output = self._step_code(plan, target_language)

            # 3. Extract files
            files = self._step_extract(code_output)

            # 4. Test in sandbox
            try:
                self._step_test(files, target_language)
            except RuntimeError as e:
                self._emit(StepName.TESTING, f"Test failed, proceeding to refactor: {e}", "error")
                self._record(StepName.TESTING, f"Failed: {e}")

            # 5. Refactor
            refactored = self._step_refactor(code_output, plan)
            files = self._step_extract(refactored)

            # 6. Re-test
            try:
                self._step_test(files, target_language)
            except RuntimeError:
                self._emit(StepName.TESTING, "Post-refactor test warning", "error")

            # 7. Documentation
            readme = self._step_docs(plan, refactored)

            # 8. Deploy to GitHub
            project = self.db.query(Project).filter(Project.project_id == self.project_id).first()
            repo_url = project.repo_url if project else None
            repo_url = self._step_deploy(files, readme, repo_url)

            # 9. Complete
            self._update_status(ProjectStatus.COMPLETED, repo_url=repo_url)
            self._record(StepName.COMPLETED, f"Pipeline completed. Repo: {repo_url}")
            self._emit(StepName.COMPLETED, f"Pipeline completed! Repo: {repo_url}", "status")

        except Exception as e:
            error = f"Pipeline failed: {e}\n{traceback.format_exc()}"
            self._emit(StepName.ERROR, error, "error")
            self._update_status(ProjectStatus.FAILED)
            self._record(StepName.ERROR, error)
            print(f"Pipeline failed for {self.project_id}: {e}")
        finally:
            self._cleanup_sandbox()
