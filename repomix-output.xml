<file path="Documents/SaaS-Wrapper/autogpt_saas_wrapper.py">
"""
AutoGPT SaaS Wrapper - Concept Studio & Security Scanner
========================================================
Ready-to-use Python client for calling your AutoGPT agents
from any external frontend (Flask, FastAPI, Django, etc.)

Author: Otto (AutoGPT Co-Pilot) for Martin Hatch
Date: Feb 2026
"""

import requests
import time
from dataclasses import dataclass, field, asdict
from typing import Optional, List, Dict, Any
from enum import Enum


# ============================================================
# CONFIGURATION
# ============================================================

AUTOGPT_BASE_URL = "https://backend.agpt.co/external-api/v1"

# Your agent graph IDs
CONCEPT_STUDIO_GRAPH_ID = "cd0870a3-0a0f-425e-91cf-041b84548ef7"
SECURITY_SCANNER_GRAPH_ID = "9575f0ef-7da2-4f5b-905a-d5a8d956f17a"


# ============================================================
# DATA MODELS - CONCEPT STUDIO INPUTS
# ============================================================

@dataclass
class ConceptStudioInput:
    """
    Input schema for Business Concept Studio agent.
    
    Example:
        input_data = ConceptStudioInput(
            prompt="A subscription service for AI-generated bedtime stories",
            industry="EdTech / Entertainment",
            target_audience="Parents of children aged 3-8",
            budget="$50k - $100k",
            timeline="3 months to MVP",
            style="Playful, whimsical, warm",
            modules="brainstorm, business_plan, branding, mockups",
            additional_notes="Focus on mobile-first experience."
        )
    """
    prompt: str                                 # The main concept description
    industry: str = ""                          # e.g. "EdTech / Entertainment"
    target_audience: str = ""                   # e.g. "Parents of children aged 3-8"
    budget: str = ""                            # e.g. "$50k - $100k"
    timeline: str = ""                          # e.g. "3 months to MVP"
    style: str = ""                             # e.g. "Playful, whimsical, warm"
    modules: str = "brainstorm"                 # Comma-separated: brainstorm, business_plan, branding, mockups, market_research, ui_ux
    additional_notes: str = ""                  # Any extra context

    def to_dict(self) -> Dict[str, Any]:
        """Convert to API payload, excluding empty fields."""
        return {k: v for k, v in asdict(self).items() if v}


# ============================================================
# DATA MODELS - SECURITY SCANNER INPUTS
# ============================================================

class ScanPreset(Enum):
    STANDARD = "standard"
    STRICT = "strict"
    QUICK = "quick"


@dataclass
class SecurityScannerInput:
    """
    Input schema for Code Security Scanner agent.
    
    Example:
        input_data = SecurityScannerInput(
            code_input='import os\napi_key = "sk-123"\nprint(api_key)',
            language="python",
            target_score=9,
            include_autofix=True
        )
    """
    code_input: str                                 # The code to scan
    language: str = "python"                        # Programming language
    preset: str = "standard"                        # standard | strict | quick
    target_score: int = 8                           # Target security score (1-10)
    max_iterations: int = 3                         # Max scan iterations
    include_cwe: bool = True                        # Include CWE compliance
    include_owasp: bool = True                      # Include OWASP compliance
    include_autofix: bool = True                    # Auto-fix vulnerabilities
    include_report: bool = True                     # Generate report
    include_recommendations: bool = True            # Include recommendations
    include_priority_ranking: bool = True            # Rank issues by priority

    def to_dict(self) -> Dict[str, Any]:
        """Convert to API payload in the format the agent expects."""
        return {
            "payload": {
                "code_input": self.code_input,
                "language": self.language,
                "preset": self.preset,
                "target_score": self.target_score,
                "max_iterations": self.max_iterations,
                "include_cwe": self.include_cwe,
                "include_owasp": self.include_owasp,
                "include_autofix": self.include_autofix,
                "include_report": self.include_report,
                "include_recommendations": self.include_recommendations,
                "include_priority_ranking": self.include_priority_ranking,
            },
            "target_score": self.target_score,
            "max_iterations": self.max_iterations,
            "include_cwe": self.include_cwe,
            "include_owasp": self.include_owasp,
            "include_autofix": self.include_autofix,
            "include_report": self.include_report,
            "include_recommendations": self.include_recommendations,
            "include_priority_ranking": self.include_priority_ranking,
            "preset": self.preset,
        }


# ============================================================
# OUTPUT MODELS
# ============================================================

@dataclass
class SecurityIssue:
    """A single security vulnerability found by the scanner."""
    description: str = ""
    priority: str = ""                              # "high", "medium", "low"
    fix: str = ""


@dataclass
class SecurityScanResult:
    """
    Output from Security Scanner agent.
    
    Example output:
        result.status            => "completed"
        result.initial_score     => "7"
        result.final_score       => "9"
        result.issues_found[0]   => SecurityIssue(description="Hardcoded API credentials", ...)
        result.fixed_code        => "<corrected code string>"
        result.compliance        => {"cwe": True, "owasp": True}
    """
    status: str = ""
    scan_id: str = ""
    initial_score: str = ""
    final_score: str = ""
    issues_found: List[SecurityIssue] = field(default_factory=list)
    fixed_code: str = ""
    compliance: Dict[str, bool] = field(default_factory=dict)

    @classmethod
    def from_raw(cls, data: dict) -> "SecurityScanResult":
        """Parse raw API response into structured result."""
        issues = [SecurityIssue(**i) for i in data.get("issues_found", [])]
        return cls(
            status=data.get("status", ""),
            scan_id=data.get("scan_id", ""),
            initial_score=data.get("initial_score", ""),
            final_score=data.get("final_score", ""),
            issues_found=issues,
            fixed_code=data.get("fixed_code", ""),
            compliance=data.get("compliance", {}),
        )


# ============================================================
# MAIN CLIENT
# ============================================================

class AutoGPTClient:
    """
    Python client for AutoGPT External API.
    
    Usage:
        client = AutoGPTClient(api_key="your_api_key_here")
        
        # Run Concept Studio
        result = client.run_concept_studio(
            ConceptStudioInput(prompt="AI pet care SaaS")
        )
        
        # Run Security Scanner
        result = client.run_security_scan(
            SecurityScannerInput(code_input="import os...")
        )
    """
    
    def __init__(self, api_key: str, base_url: str = AUTOGPT_BASE_URL):
        self.api_key = api_key
        self.base_url = base_url
        self.headers = {
            "X-API-Key": api_key,
            "Content-Type": "application/json",
        }
    
    # ---------------------------------------------------------
    # CORE API METHODS
    # ---------------------------------------------------------
    
    def execute_graph(
        self,
        graph_id: str,
        input_data: Dict[str, Any],
        graph_version: int = 1,
    ) -> Dict[str, Any]:
        """
        Execute an agent graph and return the execution response.
        
        API Endpoint: POST /v1/graphs/{graph_id}/execute/{version}
        
        Returns execution metadata including execution_id to poll for results.
        """
        url = f"{self.base_url}/graphs/{graph_id}/execute/{graph_version}"
        
        response = requests.post(
            url,
            headers=self.headers,
            json={"node_input": input_data},
            timeout=30,
        )
        response.raise_for_status()
        return response.json()
    
    def get_execution_results(
        self,
        graph_id: str,
        execution_id: str,
    ) -> Dict[str, Any]:
        """
        Get results of an agent execution.
        
        API Endpoint: GET /v1/graphs/{graph_id}/executions/{exec_id}/results
        
        Response schema:
        {
            "execution_id": "str",
            "status": "COMPLETED" | "RUNNING" | "FAILED",
            "nodes": [ {"node_id": "...", "input": {...}, "output": {...}} ],
            "output": [ {"output_name": "value"} ]
        }
        """
        url = f"{self.base_url}/graphs/{graph_id}/executions/{execution_id}/results"
        
        response = requests.get(
            url,
            headers=self.headers,
            timeout=30,
        )
        response.raise_for_status()
        return response.json()
    
    def poll_until_complete(
        self,
        graph_id: str,
        execution_id: str,
        poll_interval: float = 5.0,
        timeout: float = 600.0,
    ) -> Dict[str, Any]:
        """
        Poll for execution results until complete or timeout.
        
        Args:
            graph_id: The agent graph ID
            execution_id: The execution ID from execute_graph()
            poll_interval: Seconds between polls (default 5s)
            timeout: Max wait time in seconds (default 10 minutes)
            
        Returns:
            Full execution result dict
            
        Raises:
            TimeoutError: If execution doesn't complete within timeout
            RuntimeError: If execution fails
        """
        start = time.time()
        
        while time.time() - start < timeout:
            result = self.get_execution_results(graph_id, execution_id)
            status = result.get("status", "")
            
            if status == "COMPLETED":
                return result
            elif status == "FAILED":
                raise RuntimeError(f"Execution {execution_id} failed: {result}")
            
            time.sleep(poll_interval)
        
        raise TimeoutError(f"Execution {execution_id} timed out after {timeout}s")
    
    def get_user_info(self) -> Dict[str, Any]:
        """
        Test API connection and get user info.
        
        API Endpoint: GET /v1/me
        
        Response: 
        {
            "id": "user-uuid",
            "name": "Martin Hatch",
            "email": "...",
            "timezone": "..."
        }
        """
        response = requests.get(
            f"{self.base_url}/me",
            headers=self.headers,
            timeout=10,
        )
        response.raise_for_status()
        return response.json()
    
    # ---------------------------------------------------------
    # CONCEPT STUDIO
    # ---------------------------------------------------------
    
    def run_concept_studio(
        self,
        input_data: ConceptStudioInput,
        wait_for_result: bool = True,
        poll_interval: float = 10.0,
        timeout: float = 900.0,     # 15 min (Concept Studio can take ~10 min)
    ) -> Dict[str, Any]:
        """
        Run the Business Concept Studio agent.
        
        Args:
            input_data: ConceptStudioInput instance
            wait_for_result: If True, polls until complete (default: True)
            poll_interval: Seconds between status checks
            timeout: Max wait time
            
        Returns:
            If wait_for_result=True: Full execution result with outputs
            If wait_for_result=False: Execution metadata (including execution_id)
        """
        exec = self.execute_graph(
            graph_id=CONCEPT_STUDIO_GRAPH_ID,
            input_data=input_data.to_dict(),
        )
        
        if not wait_for_result:
            return exec
        
        execution_id = exec.get("id") or exec.get("execution_id", "")
        return self.poll_until_complete(
            graph_id=CONCEPT_STUDIO_GRAPH_ID,
            execution_id=execution_id,
            poll_interval=poll_interval,
            timeout=timeout,
        )
    
