import React, { useState, useEffect, useRef } from 'react';
import { api } from './api';

const STEP_ORDER = ['init', 'planning', 'coding', 'testing', 'refactoring', 'documentation', 'deployment', 'completed'];
const STEP_ICONS = {
  init: '🚀', planning: '📋', coding: '💻', testing: '🧪',
  refactoring: '🔧', documentation: '📄', deployment: '🚢', completed: '✅', error: '❌',
};

export default function PipelineView({ project, onClose, onRefresh }) {
  const [events, setEvents] = useState([]);
  const [outputs, setOutputs] = useState([]);
  const [running, setRunning] = useState(false);
  const [expandedStep, setExpandedStep] = useState(null);
  const eventSourceRef = useRef(null);

  // Load existing outputs
  useEffect(() => {
    api.getProject(project.project_id)
      .then(p => {
        if (p.status === 'running') setRunning(true);
      });
    fetch(`/api/projects/${project.project_id}/outputs`)
      .then(r => r.json())
      .then(setOutputs)
      .catch(console.error);
  }, [project.project_id]);

  const startPipeline = async () => {
    setRunning(true);
    setEvents([]);
    try {
      await api.launch(project.project_id);
      // Connect SSE
      const es = new EventSource(api.streamUrl(project.project_id));
      eventSourceRef.current = es;
      es.onmessage = (msg) => {
        try {
          const event = JSON.parse(msg.data);
          setEvents(prev => [...prev, event]);
          if (event.step === 'completed' || event.step === 'error') {
            es.close();
            setRunning(false);
            onRefresh();
          }
        } catch (e) {
          console.error('Parse error', e);
        }
      };
      es.onerror = () => {
        es.close();
        setRunning(false);
      };
    } catch (err) {
      alert('Failed to launch: ' + err.message);
      setRunning(false);
    }
  };

  useEffect(() => {
    return () => {
      if (eventSourceRef.current) eventSourceRef.current.close();
    };
  }, []);

  const currentStep = events.length > 0 ? events[events.length - 1].step : null;

  return (
    <div style={{ border: '1px solid #ccc', borderRadius: 8, padding: 20, marginTop: 20 }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <h2>{project.project_name}</h2>
        <button onClick={onClose}>✕ Close</button>
      </div>
      <p><em>{project.description}</em></p>
      <p>Status: <strong>{project.status}</strong>
        {project.repo_url && (
          <> | <a href={project.repo_url} target="_blank" rel="noreferrer">GitHub Repo</a></>
        )}
      </p>

      {/* Pipeline progress */}
      <div style={{ display: 'flex', gap: 8, marginBottom: 16, flexWrap: 'wrap' }}>
        {STEP_ORDER.map(step => {
          const isActive = currentStep === step;
          const isPast = events.some(e => e.step === step);
          return (
            <div key={step} style={{
              padding: '6px 12px', borderRadius: 4, fontSize: 13,
              background: isActive ? '#4CAF50' : isPast ? '#C8E6C9' : '#eee',
              color: isActive ? '#fff' : '#333',
              fontWeight: isActive ? 'bold' : 'normal',
            }}>
              {STEP_ICONS[step] || '⬜'} {step}
            </div>
          );
        })}
      </div>

      {/* Launch button */}
      {!running && project.status !== 'running' && (
        <button onClick={startPipeline} style={{ padding: '10px 20px', fontSize: 16 }}>
          🚀 Launch Pipeline
        </button>
      )}
      {running && <p>⏳ Pipeline running...</p>}

      {/* Live events */}
      {events.length > 0 && (
        <div style={{ marginTop: 16 }}>
          <h3>Live Events</h3>
          <div style={{ maxHeight: 300, overflowY: 'auto', background: '#1e1e1e', color: '#0f0', padding: 12, borderRadius: 4, fontFamily: 'monospace', fontSize: 13 }}>
            {events.map((e, i) => (
              <div key={i}>
                {STEP_ICONS[e.step] || '▸'} [{e.step}] {e.message}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Past outputs */}
      {outputs.length > 0 && (
        <div style={{ marginTop: 16 }}>
          <h3>Pipeline Outputs</h3>
          {outputs.map(o => (
            <div key={o.output_id} style={{ marginBottom: 8 }}>
              <button onClick={() => setExpandedStep(expandedStep === o.output_id ? null : o.output_id)}
                      style={{ cursor: 'pointer' }}>
