// Config
const WEBHOOK_URL = 'https://backend.agpt.co/api/integrations/generic_webhook/webhooks/7b2eaeb1-f223-4eb4-aceb-5d2263fbab78/ingress';

// Simple Markdown-to-HTML parser
function parseMarkdown(text) {
  return text
    // Code blocks
    .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code class="lang-$1">$2</code></pre>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // H2
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    // H3
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    // Bold
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    // Tables
    .replace(/(\|.+\|\n)+/g, (match) => {
      const rows = match.trim().split('\n').filter(r => !r.match(/^[\|\-\s]+$/));
      if (rows.length === 0) return match;
      const header = rows[0].split('|').filter(c => c.trim()).map(c => `<th>${c.trim()}</th>`).join('');
      const body = rows.slice(1).map(r => {
        const cells = r.split('|').filter(c => c.trim()).map(c => `<td>${c.trim()}</td>`).join('');
        return `<tr>${cells}</tr>`;
      }).join('');
      return `<table><thead><tr>${header}</tr></thead><tbody>${body}</tbody></table>`;
    })
    // List items
    .replace(/^\- (.+)$/gm, '<li>$1</li>')
    // Line breaks
    .replace(/\n/g, '<br>');
}

async function startScan() {
  const codeInput = document.getElementById('code-input').value.trim();
  const language = document.getElementById('language').value;
  const preset = document.getElementById('preset').value;
  const targetScore = parseInt(document.getElementById('target').value);
  const includeAutofix = document.getElementById('include-autofix').checked;
  const includeOwasp = document.getElementById('include-owasp').checked;
  const includeCwe = document.getElementById('include-cwe').checked;

  if (!codeInput) {
    alert('Please paste your code first!');
    return;
  }

  // Show loading
  const scanBtn = document.getElementById('scan-btn');
  const loading = document.getElementById('loading');
  const results = document.getElementById('results');

  scanBtn.disabled = true;
  results.classList.add('hidden');
  loading.classList.remove('hidden');

  try {
    const response = await fetch(WEBHOOK_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        code_input: codeInput,
        language: language,
        preset: preset,
        target_score: targetScore,
        max_iterations: 3,
        include_autofix: includeAutofix,
        include_owasp: includeOwasp,
        include_cwe: includeCwe,
        include_report: true,
        include_recommendations: true,
        include_priority_ranking: true
      })
    });

    const data = await response.json();

    // Hide loading
    loading.classList.add('hidden');
    results.classList.remove('hidden');

    // Parse results
    let analysisText = '';
    if (data.analysis) {
      analysisText = Array.isArray(data.analysis) ? data.analysis.join('\n') : data.analysis;
    } else {
      analysisText = JSON.stringify(data, null, 2);
    }

    // Extract scores from text
    const scoreMatch = analysisText.match(/Target.*?(\d+)\/10.*?achieved/i);
    const initialMatch = analysisText.match(/Current:\s*(\d+)\/10/i);

    // Score badge
    const scoreBadge = document.getElementById('score-badge');
    if (scoreMatch) {
      const finalScore = parseInt(scoreMatch[1]);
      scoreBadge.textContent = `Score: ${finalScore}/10 \u2705`;
      scoreBadge.className = `score-badge ${finalScore >= 8 ? 'score-high' : finalScore >= 6 ? 'score-med' : 'score-low'}`;
    } else if (initialMatch) {
      const initial = parseInt(initialMatch[1]);
      scoreBadge.textContent = `Initial: ${initial}/10`;
      scoreBadge.className = `score-badge ${initial >= 8 ? 'score-high' : initial >= 6 ? 'score-med' : 'score-low'}`;
    } else {
      scoreBadge.textContent = 'Scan Complete';
      scoreBadge.className = 'score-badge score-high';
    }

    // Render content
    document.getElementById('results-content').innerHTML = parseMarkdown(analysisText);

  } catch (error) {
    loading.classList.add('hidden');
    results.classList.remove('hidden');
    
    document.getElementById('score-badge').textContent = 'Error';
    document.getElementById('score-badge').className = 'score-badge score-low';
    document.getElementById('results-content').innerHTML = `
      <p style="color: var(--red)"><strong>Scan failed:</strong> ${error.message}</p>
      <p style="color: var(--text-secondary); margin-top: 0.5rem">
        The scan is processing in the background. Results typically take 1-2 minutes to complete.
        Please refresh the page and try again in a moment.
      </p>
    `;
  } finally {
    scanBtn.disabled = false;
  }
}

// Smooth scroll for nav links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function (e) {
    e.preventDefault();
    const target = document.querySelector(this.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth' });
  });
});
