import asyncio
import json
import uuid
from typing import Dict, List

from fastapi import APIRouter, Depends, HTTPException, BackgroundTasks, Request
from sqlalchemy.orm import Session
from sse_starlette.sse import EventSourceResponse

from database import get_db, SessionLocal, Project as DBProject, ProjectOutput as DBProjectOutput
from models import (
    ProjectCreate, ProjectResponse, ProjectOutputResponse,
    ProjectStatus, CredentialStatus, InitiatePipelineRequest,
    PipelineEvent, StepName,
)
from pipeline import BossAgentPipeline
from config import Config

router = APIRouter()

# In-memory queues for SSE streaming
active_queues: Dict[uuid.UUID, List[asyncio.Queue]] = {}


def broadcast_event(project_id: uuid.UUID, event: PipelineEvent):
    """Called synchronously from pipeline to push events to all SSE subscribers."""
    if project_id in active_queues:
        for q in active_queues[project_id]:
            try:
                q.put_nowait(event)
            except Exception:
                pass


# ---------------- PROJECT CRUND ----------------

@router.post("/projects", response_model=ProjectResponse, status_code=201)
def create_project(project: ProjectCreate, db: Session = Depends(get_db)):
    db_project = DBProject(
        project_name=project.project_name,
        description=project.description,
        repo_url=project.repo_url,
        status=ProjectStatus.PENDING.value,
    )
    db.add(db_project)
    db.commit()
    db.refresh(db_project)
    return ProjectResponse.model_validate(db_project)


@router.get("/projects", response_model=List[ProjectResponse])
def list_projects(skip: int = 0, limit: int = 100, db: Session = Depends(get_db)):
    projects = db.query(DBProject).order_by(DBProject.created_at.desc()).offset(skip).limit(limit).all()
    return [ProjectResponse.model_validate(p) for p in projects]


@router.get("/projects/{project_id}", response_model=ProjectResponse)
def get_project(project_id: uuid.UUID, db: Session = Depends(get_db)):
    project = db.query(DBProject).filter(DBProject.project_id == project_id).first()
    if not project:
        raise HTTPException(404, "Project not found")
    return ProjectResponse.model_validate(project)


@router.delete("/projects/{project_id}", status_code=204)
def delete_project(project_id: uuid.UUID, db: Session = Depends(get_db)):
    project = db.query(DBProject).filter(DBProject.project_id == project_id).first()
    if not project:
        raise HTTPException(404, "Project not found")
    db.delete(project)
    db.commit()


@router.get("/projects/{project_id}/outputs", response_model=List[ProjectOutputResponse])
def get_project_outputs(project_id: uuid.UUID, db: Session = Depends(get_db)):
    outputs = (
        db.query(DBProjectOutput)
        .filter(DBProjectOutput.project_id == project_id)
        .order_by(DBProjectOutput.timestamp)
        .all()
    )
    return [ProjectOutputResponse.model_validate(o) for o in outputs]


# ---------------- PIPELINE LAUNCH ----------------

@router.post("/projects/{project_id}/pipeline")
def initiate_pipeline(
    project_id: uuid.UUID,
    request_data: InitiatePipelineRequest,
    background_tasks: BackgroundTasks,
    db: Session = Depends(get_db),
):
    project = db.query(DBProject).filter(DBProject.project_id == project_id).first()
    if not project:
        raise HTTPException(404, "Project not found")
    if project.status == ProjectStatus.RUNNING.value:
        raise HTTPException(400, "Pipeline already running")

    project_name = project.project_name
    description = project.description

    def pipeline_runner():
        """Runs synchronously in background thread with its own DB session."""
        task_db = SessionLocal()
        try:
            pipeline = BossAgentPipeline(
                project_id=project_id,
                project_name=project_name,
                description=description,
                db=task_db,
                publish_event=lambda e: broadcast_event(project_id, e),
            )
            pipeline.run_pipeline(
                initial_prompt=request_data.initial_prompt,
                project_type=request_data.project_type,
                target_language=request_data.target_language,
                deploy_target=request_data.deploy_target,
            )
        except Exception as e:
            print(f"Pipeline background error: {e}")
        finally:
            task_db.close()

    background_tasks.add_task(pipeline_runner)
    return {"message": "Pipeline launched", "project_id": str(project_id)}


# ---------------- SSE STREAMING ----------------

@router.get("/projects/{project_id}/stream")
async def stream_pipeline_events(project_id: uuid.UUID, request: Request):
    queue: asyncio.Queue = asyncio.Queue()

    if project_id not in active_queues:
        active_queues[project_id] = []
    active_queues[project_id].append(queue)

    async def event_generator():
        try:
            while True:
                if await request.is_disconnected():
                    break
                try:
                    event = await asyncio.wait_for(queue.get(), timeout=30)
                    yield json.dumps(event.model_dump())
                    # Stop after completed or error
                    if event.step in (StepName.COMPLETED, StepName.ERROR):
                        break
                except asyncio.TimeoutError:
                    # Send keepalive
                    yield json.dumps({"step": "keepalive", "message": "", "event_type": "ping"})
        finally:
            if queue in active_queues.get(project_id, []):
                active_queues[project_id].remove(queue)

    return EventSourceResponse(event_generator())


# ---------------- CREDENTIALS ----------------

@router.get("/credentials", response_model=CredentialStatus)
def check_credentials():
    return CredentialStatus(
        groq_api_key_set=bool(Config.GROQ_API_KEY),
        e2b_api_key_set=bool(Config.E2B_API_KEY),
        github_token_set=bool(Config.GITHUB_ACCESS_TOKEN),
    )


@router.get("/health")
def health_check():
    return {"status": "ok", "service": "Boss Agent API"}
