generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}
model User {
  id                String   @id @db.Uuid
  email             String   @unique
  plan              String   @default("free")
  credits_remaining Int      @default(5)
  created_at        DateTime @default(now())
}
